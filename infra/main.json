      "apiVersion": "2020-02-02",
      "name": "[format('appi-{0}', variables('resourceToken'))]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web",
