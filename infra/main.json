    "containerAppsEnv": {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-10-02-preview",
      "name": "[format('cae-{0}', variables('resourceToken'))]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[reference('logAnalytics').customerId]",
            "sharedKey": "[listKeys('logAnalytics', '2023-09-01').primarySharedKey]"
          }
        },
        "workloadProfiles": [
          {
            "workloadProfileType": "Consumption-GPU-NC8as-T4",
            "name": "gpu"
          }
        ],
        "zoneRedundant": false
      },
      "dependsOn": [
        "logAnalytics"
      ]
    },
    "modelApp": {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-10-02-preview",
      "name": "[format('ca-model-{0}', variables('resourceToken'))]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('id-ca-{0}', variables('resourceToken'))))]": {}
        }
      },
      "properties": {
        "environmentId": "[resourceId('Microsoft.App/managedEnvironments', format('cae-{0}', variables('resourceToken')))]",
        "workloadProfileName": "gpu",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": 8000,
            "transport": "http"
          }
        },
        "template": {
          "containers": [
            {
              "name": "vllm",
              "image": "vllm/vllm-openai:latest",
              "resources": {
                "cpu": "[json('8')]",
                "memory": "56Gi",
                "gpu": 1
              },
              "command": [
                "python3",
                "-m",
                "vllm.entrypoints.openai.api_server"
              ],
              "args": [
                "--model",
                "microsoft/Phi-4-mini-instruct",
                "--served-model-name",
                "[variables('gatewayModelName')]",
                "--port",
                "8000",
                "--trust-remote-code",
                "--max-model-len",
                "16384"
              ]
            }
          ],
          "scale": {
            "minReplicas": 1,
            "maxReplicas": 1
          }
        }
      },
      "dependsOn": [
        "containerAppsEnv",
        "containerAppsIdentity"
      ]
    },
    "modelGatewayConnection": {
      "type": "Microsoft.CognitiveServices/accounts/projects/connections",
      "apiVersion": "2025-04-01-preview",
      "name": "[format('{0}/{1}/{2}', format('foundry-{0}', variables('resourceToken')), format('project-{0}', variables('resourceToken')), 'custom-model-gateway')]",
      "properties": {
        "category": "ModelGateway",
        "target": "[format('{0}/openai', reference('apim').outputs.gatewayUrl.value)]",
        "authType": "ApiKey",
        "isSharedToAll": true,
        "credentials": {
          "key": "[listOutputsWithSecureValues('apim', '2025-04-01').subscriptionPrimaryKey]"
        },
        "metadata": {
          "deploymentInPath": "true",
          "inferenceAPIVersion": "",
          "models": "[string(createArray(createObject('name', variables('gatewayModelName'), 'properties', createObject('model', createObject('name', variables('gatewayModelName'), 'version', '1', 'format', 'OpenAI')))))]"
        }
      },
      "dependsOn": [
        "apim",
        "foundry::project"
      ]
    },
