      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "[format('id-ca-{0}', variables('resourceToken'))]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]"
    },
    "containerRegistry": {
      "type": "Microsoft.ContainerRegistry/registries",
      "apiVersion": "2023-11-01-preview",
      "name": "[toLower(replace(format('acr{0}', variables('resourceToken')), '-', ''))]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "sku": {
        "name": "Basic"
      },
      "properties": {
        "adminUserEnabled": false
      }
    },
    "acrPullAssignment": {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.ContainerRegistry/registries', toLower(replace(format('acr{0}', variables('resourceToken')), '-', '')))]",
      "name": "[guid(resourceId('Microsoft.ContainerRegistry/registries', toLower(replace(format('acr{0}', variables('resourceToken')), '-', ''))), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('id-ca-{0}', variables('resourceToken'))), variables('acrPullRoleId'))]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('acrPullRoleId'))]",
        "principalId": "[reference('containerAppsIdentity').principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "containerAppsIdentity",
        "containerRegistry"
      ]
    },
